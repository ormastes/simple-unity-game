root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,asmdef,asmref}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.shader]
indent_style = space
indent_size = 4

[*.hlsl]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
